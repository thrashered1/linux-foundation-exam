// ── LESSON LOADER ─────────────────────────────────────────────
function loadLesson(id){
  if(!LESSONS[id])return;
  S.lesson=id;
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const nav=document.getElementById('nav-'+id);
  if(nav)nav.classList.add('active');
  const L=LESSONS[id];
  document.getElementById('lBC').textContent=L.bc;
  document.getElementById('lTitle').textContent=L.title;
  const tag=document.getElementById('lTag');
  tag.textContent=L.tag; tag.className='ltag '+L.tc;
  document.getElementById('lTime').textContent='⏱ '+L.time;
  document.getElementById('lc-theory').innerHTML=L.theory;
  document.getElementById('lc-lab').innerHTML=L.lab;
  document.getElementById('lc-quiz').innerHTML=buildQuizHTML(id,L.quiz||[]);
  switchLT('theory',null);
  document.querySelector('.lesson-body').scrollTop=0;
}

function buildQuizHTML(lid,qs){
  if(!qs.length)return'<div class="prose"><p>No quiz for this lesson yet.</p></div>';
  return qs.map((q,i)=>`
<div class="quiz-q" id="qq-${lid}-${i}">
  <div class="quiz-qnum">Question ${i+1} of ${qs.length}</div>
  <div class="quiz-qtext">${q.q}</div>
  <div class="quiz-opts">
    ${q.opts.map((o,oi)=>`<button class="quiz-opt" onclick="ansQ('${lid}',${i},${oi},${q.c},\`${q.exp.replace(/`/g,"'")}\`)">${o}</button>`).join('')}
  </div>
  <div class="quiz-fb" id="qfb-${lid}-${i}"></div>
</div>`).join('')+
`<div class="lnb-row" style="margin-top:8px">
  <button class="lnb" onclick="switchLT('lab',null)">← Lab</button>
</div>`;
}

function ansQ(lid,qi,chosen,correct,exp){
  const btns=document.querySelectorAll(`#qq-${lid}-${qi} .quiz-opt`);
  btns.forEach(b=>b.disabled=true);
  btns[chosen].classList.add(chosen===correct?'correct':'wrong');
  if(chosen!==correct)btns[correct].classList.add('correct');
  const fb=document.getElementById(`qfb-${lid}-${qi}`);
  fb.className=`quiz-fb show ${chosen===correct?'ok':'fail'}`;
  fb.innerHTML=(chosen===correct?'✓ Correct. ':'✗ Incorrect. ')+exp;
}

function markDone(id,nextId){
  S.done.add(id);
  const chk=document.getElementById('chk-'+id);
  if(chk){chk.classList.add('done');chk.textContent='✓';}
  const pct=Math.round(S.done.size/S.total*100);
  document.getElementById('topProg').style.width=pct+'%';
  document.getElementById('topPct').textContent=pct+'%';
  if(nextId)loadLesson(nextId);
}

function switchLT(name,el){
  document.querySelectorAll('.l-tab').forEach((t,i)=>{
    const ns=['theory','lab','quiz'];
    t.classList.toggle('active',ns[i]===name);
  });
  document.querySelectorAll('.lc').forEach(lc=>{
    lc.classList.toggle('active',lc.id==='lc-'+name);
  });
  if(el)return;
  document.querySelectorAll('.l-tab').forEach((t,i)=>{
    if(['theory','lab','quiz'][i]===name)t.classList.add('active');
    else t.classList.remove('active');
  });
}

function copyCode(btn){
  const pre=btn.closest('.cb').querySelector('pre');
  const text=pre.innerText;
  navigator.clipboard.writeText(text).then(()=>{
    btn.textContent='Copied!';
    setTimeout(()=>btn.textContent='Copy',1500);
  });
}

