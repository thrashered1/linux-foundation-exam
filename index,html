<!DOCTYPE html>
<html lang="bg">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Linux Foundation — Interactive Learning</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--bg:#0F1117;--sf:#161B27;--card:#1C2333;--bd:#2A3347;--acc:#E8A020;--acc2:#3B82F6;--green:#22C55E;--red:#EF4444;--text:#E2E8F0;--muted:#64748B;--dim:#334155;--mono:'JetBrains Mono',monospace;--sans:'Inter',sans-serif}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--text);font-family:var(--sans);display:flex;flex-direction:column}
/* TOPBAR */
.topbar{height:52px;background:var(--sf);border-bottom:1px solid var(--bd);display:flex;align-items:center;padding:0 24px;gap:20px;flex-shrink:0;z-index:20}
.logo-mark{width:30px;height:30px;background:var(--acc);border-radius:4px;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:13px;font-weight:700;color:#000;flex-shrink:0}
.logo-text{font-size:13px;font-weight:600}
.logo-text span{color:var(--muted);font-weight:400}
.tb-div{width:1px;height:22px;background:var(--bd)}
.tb-nav{display:flex;gap:2px}
.tb-nav a{font-size:12px;color:var(--muted);text-decoration:none;padding:5px 10px;border-radius:4px;cursor:pointer;transition:all .15s}
.tb-nav a:hover{color:var(--text);background:var(--card)}
.tb-nav a.active{color:var(--acc)}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:12px}
.prog-pill{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--bd);border-radius:20px;padding:4px 12px}
.prog-pill-label{font-size:11px;color:var(--muted);font-family:var(--mono)}
.mini-bar{width:60px;height:3px;background:var(--dim);border-radius:2px}
.mini-fill{height:100%;background:var(--acc);border-radius:2px;transition:width .5s}
.prog-pct{font-size:11px;font-family:var(--mono);color:var(--acc)}
/* LAYOUT */
.layout{display:flex;flex:1;overflow:hidden}
/* SIDEBAR */
.sidebar{width:255px;background:var(--sf);border-right:1px solid var(--bd);display:flex;flex-direction:column;overflow:hidden;flex-shrink:0}
.sb-scroll{flex:1;overflow-y:auto;padding:8px 0}
.sb-scroll::-webkit-scrollbar{width:3px}
.sb-scroll::-webkit-scrollbar-thumb{background:var(--bd)}
.sb-section{padding:16px 12px 6px}
.sb-label{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);padding:0 8px;margin-bottom:6px}
.nav-item{display:flex;align-items:center;gap:10px;padding:7px 8px;border-radius:5px;cursor:pointer;transition:all .15s;margin-bottom:1px}
.nav-item:hover{background:var(--card)}
.nav-item.active{background:rgba(232,160,32,.1)}
.nav-item.active .nav-label,.nav-item.active .nav-ic{color:var(--acc)}
.nav-ic{font-size:12px;width:16px;text-align:center;color:var(--muted);flex-shrink:0}
.nav-label{font-size:12.5px;color:var(--text);flex:1}
.nav-chk{width:14px;height:14px;border-radius:50%;border:1.5px solid var(--dim);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:8px}
.nav-chk.done{border-color:var(--green);background:rgba(34,197,94,.15);color:var(--green)}
.sb-div{height:1px;background:var(--bd);margin:8px 12px}
/* CONTENT */
.content-area{flex:1;display:flex;overflow:hidden}
.lesson-pane{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
.lh{padding:20px 28px 14px;border-bottom:1px solid var(--bd);flex-shrink:0;background:var(--sf)}
.lh-bc{font-size:11px;color:var(--muted);font-family:var(--mono);margin-bottom:6px}
.lh-title{font-size:20px;font-weight:600;letter-spacing:-.01em;line-height:1.3}
.lh-meta{display:flex;align-items:center;gap:14px;margin-top:10px}
.ltag{font-size:10px;font-family:var(--mono);font-weight:600;letter-spacing:.08em;text-transform:uppercase;padding:2px 8px;border-radius:3px}
.tag-core{background:rgba(59,130,246,.15);color:var(--acc2)}
.tag-script{background:rgba(168,85,247,.15);color:#A855F7}
.tag-net{background:rgba(34,197,94,.15);color:var(--green)}
.tag-sys{background:rgba(232,160,32,.15);color:var(--acc)}
.tag-sec{background:rgba(239,68,68,.15);color:var(--red)}
.tag-adv{background:rgba(239,68,68,.12);color:#F87171}
.lh-time{font-size:11px;color:var(--muted)}
.l-tabs{display:flex;border-bottom:1px solid var(--bd);background:var(--sf);padding:0 28px;flex-shrink:0}
.l-tab{padding:10px 16px;font-size:12px;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;margin-bottom:-1px;font-weight:500}
.l-tab:hover{color:var(--text)}
.l-tab.active{color:var(--acc);border-bottom-color:var(--acc)}
.lesson-body{flex:1;overflow-y:auto;padding:28px}
.lesson-body::-webkit-scrollbar{width:4px}
.lesson-body::-webkit-scrollbar-thumb{background:var(--bd);border-radius:2px}
.lc{display:none;flex-direction:column;gap:18px}
.lc.active{display:flex}
/* PROSE */
.prose{font-size:13.5px;line-height:1.8;color:#C8D6E5}
.prose p{margin-bottom:12px}
.prose h3{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin:22px 0 10px;padding-bottom:6px;border-bottom:1px solid var(--bd)}
.prose h3:first-child{margin-top:0}
.prose ul{padding-left:20px}
.prose li{margin-bottom:5px}
.prose strong{color:var(--text);font-weight:600}
.prose code{font-family:var(--mono);font-size:12px;background:var(--card);border:1px solid var(--bd);border-radius:4px;padding:1px 6px;color:#7DD3FC}
/* CODE BLOCK */
.cb{background:#0A0D14;border:1px solid var(--bd);border-radius:8px;overflow:hidden}
.cb-header{display:flex;align-items:center;justify-content:space-between;padding:7px 14px;background:var(--card);border-bottom:1px solid var(--bd)}
.cb-lang{font-size:10px;font-family:var(--mono);font-weight:700;letter-spacing:.08em;color:var(--muted);text-transform:uppercase}
.cb-copy{font-size:10px;color:var(--muted);cursor:pointer;padding:2px 8px;border-radius:3px;border:1px solid var(--bd);background:transparent;transition:all .15s;font-family:var(--sans)}
.cb-copy:hover{color:var(--text);border-color:var(--muted)}
.cb pre{padding:15px 18px;font-family:var(--mono);font-size:12px;line-height:1.75;overflow-x:auto;color:#A8B8CC}
.cb pre .k{color:#7DD3FC}
.cb pre .a{color:#86EFAC}
.cb pre .o{color:#475569}
.cb pre .c{color:#2D3F55}
.cb pre .s{color:#FCA5A5}
.cb pre .kw{color:#C4B5FD}
.cb pre .n{color:var(--acc)}
/* CALLOUTS */
.callout{border-left:3px solid;border-radius:0 6px 6px 0;padding:11px 15px;font-size:13px;line-height:1.65}
.c-info{border-color:var(--acc2);background:rgba(59,130,246,.06);color:#93C5FD}
.c-warn{border-color:var(--acc);background:rgba(232,160,32,.06);color:#FCD34D}
.c-danger{border-color:var(--red);background:rgba(239,68,68,.06);color:#FCA5A5}
.c-tip{border-color:var(--green);background:rgba(34,197,94,.06);color:#86EFAC}
.c-title{font-weight:700;font-size:10px;letter-spacing:.08em;text-transform:uppercase;margin-bottom:5px;opacity:.75}
/* NAV BTNS */
.lnb-row{display:flex;justify-content:space-between;padding-top:24px;border-top:1px solid var(--bd);margin-top:8px}
.lnb{padding:8px 18px;border-radius:5px;font-size:12px;font-weight:500;cursor:pointer;transition:all .15s;border:1px solid var(--bd);background:var(--card);color:var(--text);font-family:var(--sans)}
.lnb:hover{border-color:var(--acc);color:var(--acc)}
.lnb.primary{background:var(--acc);border-color:var(--acc);color:#000;font-weight:700}
.lnb.primary:hover{background:#D4901C}
.lnb:disabled{opacity:.3;cursor:not-allowed}
/* QUIZ */
.quiz-q{background:var(--card);border:1px solid var(--bd);border-radius:8px;padding:20px}
.quiz-qnum{font-size:10px;font-family:var(--mono);font-weight:700;letter-spacing:.08em;color:var(--muted);text-transform:uppercase;margin-bottom:10px}
.quiz-qtext{font-size:13.5px;line-height:1.65;margin-bottom:14px;color:var(--text)}
.quiz-qtext code{font-family:var(--mono);font-size:12px;background:var(--sf);border:1px solid var(--bd);border-radius:3px;padding:1px 6px;color:#7DD3FC}
.quiz-opts{display:flex;flex-direction:column;gap:6px}
.quiz-opt{padding:9px 14px;border-radius:5px;border:1px solid var(--bd);background:var(--sf);color:var(--text);font-size:13px;cursor:pointer;text-align:left;transition:all .15s;font-family:var(--sans)}
.quiz-opt:hover:not(:disabled){border-color:var(--acc2);background:rgba(59,130,246,.05)}
.quiz-opt.correct{border-color:var(--green);background:rgba(34,197,94,.08);color:#86EFAC}
.quiz-opt.wrong{border-color:var(--red);background:rgba(239,68,68,.08);color:#FCA5A5}
.quiz-fb{margin-top:10px;padding:10px 14px;border-radius:5px;font-size:12.5px;line-height:1.6;display:none}
.quiz-fb.show{display:block}
.quiz-fb.ok{background:rgba(34,197,94,.07);border:1px solid rgba(34,197,94,.2);color:#86EFAC}
.quiz-fb.fail{background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);color:#FCA5A5}
/* TERMINAL */
.term-pane{width:400px;min-width:340px;display:flex;flex-direction:column;border-left:1px solid var(--bd);background:#0A0D14;flex-shrink:0}
.term-tb{height:38px;background:var(--card);border-bottom:1px solid var(--bd);display:flex;align-items:center;padding:0 14px;gap:10px;flex-shrink:0}
.tdots{display:flex;gap:6px}
.td{width:11px;height:11px;border-radius:50%}
.tdr{background:#FF5F57}.tdy{background:#FFBD2E}.tdg{background:#28C840}
.t-title{font-family:var(--mono);font-size:11px;color:var(--muted);flex:1;text-align:center}
.t-acts{display:flex;gap:6px}
.t-btn{font-size:10px;color:var(--muted);padding:2px 8px;border-radius:3px;border:1px solid var(--bd);background:transparent;cursor:pointer;font-family:var(--sans);transition:all .15s}
.t-btn:hover{color:var(--text);border-color:var(--muted)}
.term-out{flex:1;overflow-y:auto;padding:14px 18px;font-family:var(--mono);font-size:12px;line-height:1.75}
.term-out::-webkit-scrollbar{width:3px}
.term-out::-webkit-scrollbar-thumb{background:var(--dim);border-radius:2px}
.tl{white-space:pre-wrap;word-break:break-all}
.tp-u{color:#22C55E;font-weight:600}.tp-a{color:#2D3748}.tp-h{color:#3B82F6}.tp-p{color:#A78BFA}.tp-s{color:#22C55E}
.t-cmd{color:#E2E8F0}.t-out{color:#475569}.t-g{color:#22C55E}.t-b{color:#60A5FA}.t-y{color:#FCD34D}.t-r{color:#F87171}.t-dim{color:#1E293B}
.t-ai{padding:8px 16px;background:rgba(34,197,94,.03);border-top:1px solid rgba(34,197,94,.08);font-size:11px;font-family:var(--mono);color:#1E3A2A;min-height:34px;line-height:1.5;transition:color .3s}
.t-ai.lit{color:#4ADE80}
.t-row{display:flex;align-items:center;padding:10px 18px;border-top:1px solid #131820;flex-shrink:0}
.t-prompt{font-family:var(--mono);font-size:12px;flex-shrink:0;white-space:nowrap}
.t-inp{flex:1;background:transparent;border:none;outline:none;font-family:var(--mono);font-size:12px;color:var(--text);caret-color:#22C55E;padding:0 4px}
/* CHAT */
.chat-panel{position:fixed;bottom:0;right:0;width:400px;height:450px;background:var(--sf);border:1px solid var(--bd);border-bottom:none;border-radius:10px 10px 0 0;display:flex;flex-direction:column;z-index:30;transform:translateY(100%);transition:transform .3s cubic-bezier(.4,0,.2,1);box-shadow:0 -8px 40px rgba(0,0,0,.5)}
.chat-panel.open{transform:translateY(0)}
.chat-ph{display:flex;align-items:center;padding:12px 16px;border-bottom:1px solid var(--bd);flex-shrink:0;cursor:pointer;user-select:none}
.chat-ptitle{font-size:13px;font-weight:600;flex:1;display:flex;align-items:center;gap:8px}
.chat-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.chat-x{font-size:16px;color:var(--muted);width:24px;height:24px;display:flex;align-items:center;justify-content:center;border-radius:4px}
.chat-x:hover{background:var(--card);color:var(--text)}
.chat-msgs{flex:1;overflow-y:auto;padding:12px 14px;display:flex;flex-direction:column;gap:10px}
.chat-msgs::-webkit-scrollbar{width:3px}
.chat-msgs::-webkit-scrollbar-thumb{background:var(--bd)}
.cm{display:flex;gap:8px;animation:fadeUp .25s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
.cm-av{width:26px;height:26px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;margin-top:1px;font-weight:700;font-family:var(--mono)}
.cm-av.ai{background:rgba(232,160,32,.15);color:var(--acc)}
.cm-av.user{background:rgba(59,130,246,.15);color:var(--acc2)}
.cm-body{flex:1}
.cm-name{font-size:10px;color:var(--muted);font-family:var(--mono);margin-bottom:3px}
.cm-text{font-size:13px;line-height:1.65;color:var(--text)}
.cm-text code{font-family:var(--mono);font-size:11.5px;background:var(--card);border:1px solid var(--bd);border-radius:3px;padding:1px 5px;color:#7DD3FC}
.cm-text pre{font-family:var(--mono);font-size:11.5px;background:#0A0D14;border:1px solid var(--bd);border-radius:5px;padding:10px 12px;margin-top:6px;overflow-x:auto;color:#86EFAC;line-height:1.65;white-space:pre}
.cm-text strong{color:#93C5FD;font-weight:600}
.t-ind{display:flex;gap:3px;padding:4px 0}
.t-dot{width:5px;height:5px;border-radius:50%;background:var(--acc);animation:tb 1.2s infinite}
.t-dot:nth-child(2){animation-delay:.2s}.t-dot:nth-child(3){animation-delay:.4s}
@keyframes tb{0%,60%,100%{transform:translateY(0);opacity:.35}30%{transform:translateY(-5px);opacity:1}}
.chat-irow{padding:10px 12px;border-top:1px solid var(--bd);display:flex;gap:8px;align-items:flex-end;flex-shrink:0}
.chat-inp{flex:1;background:var(--card);border:1px solid var(--bd);border-radius:6px;padding:8px 12px;color:var(--text);font-family:var(--sans);font-size:13px;resize:none;outline:none;min-height:38px;max-height:100px;line-height:1.5;transition:border-color .15s}
.chat-inp:focus{border-color:var(--acc)}
.chat-inp::placeholder{color:var(--muted)}
.chat-send{width:36px;height:36px;background:var(--acc);border:none;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#000;transition:all .15s;flex-shrink:0}
.chat-send:hover{background:#D4901C}
.chat-send:disabled{opacity:.35;cursor:not-allowed}
.chat-toggle{position:fixed;bottom:24px;right:24px;width:46px;height:46px;background:var(--acc);border:none;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 4px 20px rgba(232,160,32,.35);transition:all .2s;z-index:29}
.chat-toggle:hover{transform:scale(1.08)}
.chat-toggle.hidden{display:none}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--bd);border-radius:2px}
</style>
</head>
<body>
<div class="topbar">
  <div class="logo-mark">LF</div>
  <div class="logo-text">Linux Foundation <span>/ Interactive</span></div>
  <div class="tb-div"></div>
  <nav class="tb-nav">
    <a class="active">Learn</a><a>Labs</a><a>Reference</a><a>Certification</a>
  </nav>
  <div class="tb-right">
    <div class="prog-pill">
      <span class="prog-pill-label">Progress</span>
      <div class="mini-bar"><div class="mini-fill" id="topProg" style="width:0%"></div></div>
      <span class="prog-pct" id="topPct">0%</span>
    </div>
  </div>
</div>
<div class="layout">
  <div class="sidebar">
    <div class="sb-scroll" id="sidebarContent"></div>
  </div>
  <div class="content-area">
    <div class="lesson-pane">
      <div class="lh">
        <div class="lh-bc" id="lBC">Linux Essentials › File System</div>
        <div class="lh-title" id="lTitle">Linux File System Hierarchy</div>
        <div class="lh-meta">
          <span class="ltag tag-core" id="lTag">Core Concept</span>
          <span class="lh-time" id="lTime">⏱ 15 min</span>
        </div>
      </div>
      <div class="l-tabs">
        <div class="l-tab active" onclick="switchLT('theory',this)">Theory</div>
        <div class="l-tab" onclick="switchLT('lab',this)">Lab Exercise</div>
        <div class="l-tab" onclick="switchLT('quiz',this)">Assessment</div>
      </div>
      <div class="lesson-body">
        <div id="lc-theory" class="lc active"></div>
        <div id="lc-lab" class="lc"></div>
        <div id="lc-quiz" class="lc"></div>
      </div>
    </div>
    <div class="term-pane">
      <div class="term-tb">
        <div class="tdots"><div class="td tdr"></div><div class="td tdy"></div><div class="td tdg"></div></div>
        <div class="t-title">bash — user@linux-foundation</div>
        <div class="t-acts">
          <button class="t-btn" onclick="clearTerm()">clear</button>
          <button class="t-btn" onclick="termHelp()">help</button>
        </div>
      </div>
      <div class="term-out" id="termOut"></div>
      <div class="t-ai" id="tHint">// Type a command and press Enter</div>
      <div class="t-row">
        <span class="t-prompt"><span class="tp-u">user</span><span class="tp-a">@</span><span class="tp-h">lf</span>:<span class="tp-p" id="tPath">~</span><span class="tp-s">$&nbsp;</span></span>
        <input class="t-inp" id="tInp" autocomplete="off" spellcheck="false" onkeydown="htk(event)">
      </div>
    </div>
  </div>
</div>
<div class="chat-panel" id="chatPanel">
  <div class="chat-ph" onclick="toggleChat()">
    <div class="chat-ptitle"><div class="chat-dot"></div>AI Instructor</div>
    <div class="chat-x">×</div>
  </div>
  <div class="chat-msgs" id="chatMsgs"></div>
  <div class="chat-irow">
    <textarea class="chat-inp" id="chatInp" placeholder="Ask about Linux..." rows="1" onkeydown="hck(event)"></textarea>
    <button class="chat-send" id="chatSend" onclick="sendChat()">↑</button>
  </div>
</div>
<button class="chat-toggle" id="chatTgl" onclick="toggleChat()">🤖</button>
<script>

// ── STATE ──────────────────────────────────────────────────────
const S={lesson:'filesystem',done:new Set(),total:12,aiThinking:false,chatHist:[],chatOpen:false,cwd:'/home/user',th:[],hi:-1};

// ── SIDEBAR DATA ───────────────────────────────────────────────
const NAV=[
  {section:'Essentials',items:[
    {id:'filesystem',label:'File System Hierarchy'},
    {id:'navigation',label:'Navigation & Paths'},
    {id:'files',label:'File Operations'},
    {id:'text',label:'Text Processing'},
  ]},
  {section:'System',items:[
    {id:'permissions',label:'Permissions & Ownership'},
    {id:'processes',label:'Processes & Signals'},
    {id:'pipes',label:'Pipes & Redirection'},
    {id:'systemd',label:'systemd & Services'},
  ]},
  {section:'Networking',items:[
    {id:'networking',label:'Network Fundamentals'},
    {id:'ssh',label:'SSH & Remote Access'},
  ]},
  {section:'Scripting',items:[
    {id:'bash',label:'Bash Scripting'},
    {id:'regex',label:'grep, awk & sed'},
  ]},
  {section:'Advanced',items:[
    {id:'storage',label:'Disk & Storage'},
    {id:'security',label:'Security Hardening'},
  ]},
];

function buildSidebar(){
  let h='';
  NAV.forEach(sec=>{
    h+=`<div class="sb-section"><div class="sb-label">${sec.section}</div>`;
    sec.items.forEach(it=>{
      h+=`<div class="nav-item" id="nav-${it.id}" onclick="loadLesson('${it.id}')">
        <span class="nav-ic">▸</span>
        <span class="nav-label">${it.label}</span>
        <span class="nav-chk" id="chk-${it.id}"></span>
      </div>`;
    });
    h+='</div><div class="sb-div"></div>';
  });
  document.getElementById('sidebarContent').innerHTML=h;
}

// ── LESSON DEFINITIONS ─────────────────────────────────────────
const cb=(lang,code)=>`<div class="cb"><div class="cb-header"><span class="cb-lang">${lang}</span><button class="cb-copy" onclick="copyCode(this)">Copy</button></div><pre>${code}</pre></div>`;
const callout=(type,title,body)=>`<div class="callout c-${type}"><div class="c-title">${title}</div>${body}</div>`;
