async function runCmd(raw){
  tprompt(raw);
  if(raw.includes('&&')){
    for(const c of raw.split('&&').map(x=>x.trim()))await runCmd(c);
    return;
  }
  const args=raw.trim().split(/\s+/),cmd=args[0];
  let out=null,err=null;

  switch(cmd){
    case 'help':termHelp();break;
    case 'pwd':out=S.cwd;break;
    case 'whoami':out='user';break;
    case 'id':out='uid=1000(user) gid=1000(user) groups=1000(user),27(sudo),998(docker)';break;
    case 'date':out=new Date().toString();break;
    case 'uname':out=args.includes('-a')?'Linux linux-foundation 6.1.0 #1 SMP x86_64 GNU/Linux':'Linux';break;
    case 'history':out=S.th.slice(0,20).reverse().map((c,i)=>`  ${String(i+1).padStart(3)} ${c}`).join('\n');break;
    case 'clear':clearTerm();break;
    case 'groups':out='user sudo docker';break;
    case 'env':out='HOME=/home/user\nUSER=user\nPATH=/usr/local/bin:/usr/bin:/bin\nSHELL=/bin/bash\nTERM=xterm-256color';break;
    case 'ls':{
      let path=S.cwd,hidden=false,longf=false;
      for(const a of args.slice(1)){
        if(a.startsWith('-')){if(a.includes('a'))hidden=true;if(a.includes('l'))longf=true;}
        else path=rp(a);
      }
      const n=FS[path];
      if(!n){err=`ls: cannot access '${args.slice(1).find(a=>!a.startsWith('-'))||''}': No such file or directory`;break;}
      if(n.type==='file'){out=path.split('/').pop();break;}
      let ch=[...n.children];
      if(!hidden)ch=ch.filter(c=>!c.startsWith('.'));
      ch.sort();
      if(longf){
        const lines=['total '+(ch.length*4)];
        ch.forEach(c=>{const fp=norm(path+'/'+c);const cn=FS[fp];const isd=cn?.type==='dir';lines.push(`${isd?'drwxr-xr-x':'-rw-r--r--'}  1 user user  ${String(cn?.content?.length||4096).padStart(6)} Jun 27 ${c}${isd?'/':''}`);});
        out=lines.join('\n');
      }else{out=ch.map(c=>{const fp=norm(path+'/'+c);return FS[fp]?.type==='dir'?c+'/':c;}).join('   ');}
      break;
    }
    case 'cd':{
      const t=args[1]||'/home/user';
      const np=rp(t);
      if(!FS[np]){err=`bash: cd: ${t}: No such file or directory`;break;}
      if(FS[np].type!=='dir'){err=`bash: cd: ${t}: Not a directory`;break;}
      S.cwd=np;updPath();break;
    }
    case 'cat':{
      if(args.length<2){err='cat: missing operand';break;}
      const parts2=args.slice(1).filter(a=>!a.startsWith('>'));
      for(const a of parts2){
        const fp=rp(a);const n=FS[fp];
        if(!n){tp('t-r',`cat: ${a}: No such file or directory`);continue;}
        if(n.type==='dir'){tp('t-r',`cat: ${a}: Is a directory`);continue;}
        if(out===null)out='';out+=n.content;
      }
      break;
    }
    case 'mkdir':{
      const name=args[args.length-1];
      const fp=rp(name);
      if(FS[fp]){err=`mkdir: cannot create directory '${name}': File exists`;break;}
      const par=fp.slice(0,fp.lastIndexOf('/'))||'/';
      if(!FS[par]||FS[par].type!=='dir'){err=`mkdir: cannot create directory '${name}': No such file or directory`;break;}
      FS[fp]={type:'dir',children:[]};FS[par].children.push(fp.split('/').pop());
      break;
    }
    case 'touch':{
      if(args.length<2){err='touch: missing file operand';break;}
      for(const a of args.slice(1)){
        const fp=rp(a);
        if(!FS[fp]){const par=fp.slice(0,fp.lastIndexOf('/'))||'/';if(FS[par]){FS[fp]={type:'file',content:''};FS[par].children.push(fp.split('/').pop());}}
      }
      break;
    }
    case 'echo':{
      const redir=raw.indexOf('>');
      let text=args.slice(1).join(' ').replace(/^["']|["']$/g,'');
      if(redir>0){
        const app=raw[redir+1]==='>';
        const fp=rp(raw.slice(redir+(app?2:1)).trim());
        const content=args.slice(1).join(' ').replace(/>+.*/,'').trim().replace(/^["']|["']$/g,'');
        if(app&&FS[fp])FS[fp].content+=content+'\n';
        else{const par=fp.slice(0,fp.lastIndexOf('/'))||'/';FS[fp]={type:'file',content:content+'\n'};if(FS[par]&&!FS[par].children.includes(fp.split('/').pop()))FS[par].children.push(fp.split('/').pop());}
        break;
      }
      out=text;break;
    }
    case 'grep':{
      const flags=args.filter(a=>a.startsWith('-')).join('');
      const nonFlags=args.slice(1).filter(a=>!a.startsWith('-'));
      const pat=nonFlags[0]?.replace(/^["']|["']$/g,'');
      const file=nonFlags[1];
      if(!pat){err='grep: missing pattern';break;}
      const fp=file?rp(file):null;
      const n=fp?FS[fp]:null;
      if(fp&&!n){err=`grep: ${file}: No such file or directory`;break;}
      const content=n?n.content:'';
      const lines2=content.split('\n');
      const ci=flags.includes('i'),inv=flags.includes('v'),cnt=flags.includes('c'),ln=flags.includes('n');
      let matches=lines2.filter(l=>{const m=ci?l.toLowerCase().includes(pat.toLowerCase()):l.includes(pat);return inv?!m:m;});
      if(cnt)out=String(matches.length);
      else if(ln)out=matches.map((l,i)=>`${i+1}:${l}`).join('\n');
      else out=matches.join('\n');
      break;
    }
    case 'wc':{
      if(!args.includes('-l')){err='wc: only -l is supported here';break;}
      const farg=args.filter(a=>!a.startsWith('-')).pop();
      if(!farg){err='wc: missing file';break;}
      const fp=rp(farg);const n=FS[fp];
      if(!n){err=`wc: ${farg}: No such file or directory`;break;}
      out=`${n.content.split('\n').length} ${farg}`;break;
    }
    case 'cut':{
      const dIdx=args.indexOf('-d'),fIdx=args.indexOf('-f');
      const delim=dIdx>=0?args[dIdx+1]:'\t';
      const field=fIdx>=0?parseInt(args[fIdx+1])-1:0;
      const farg=args.filter(a=>!a.startsWith('-')&&args.indexOf(a)>Math.max(dIdx,fIdx)).pop();
      const fp=farg?rp(farg):null;const n=fp?FS[fp]:null;
      if(!n){err=`cut: ${farg||'?'}: No such file or directory`;break;}
      out=n.content.split('\n').map(l=>l.split(delim)[field]||'').filter(Boolean).join('\n');break;
    }
    case 'head':{
      const n2=args.find(a=>a.startsWith('-')&&!isNaN(a.slice(1)))?parseInt(args.find(a=>a.startsWith('-')).slice(1)):10;
      const farg=args.filter(a=>!a.startsWith('-')).pop();
      const fp=farg?rp(farg):null;const n=fp?FS[fp]:null;
      if(!n){err=`head: ${farg||'?'}: No such file or directory`;break;}
      out=n.content.split('\n').slice(0,n2).join('\n');break;
    }
    case 'tail':{
      const follow=args.includes('-f');
      const n2=args.find(a=>a.startsWith('-n'))?parseInt(args[args.indexOf('-n')+1]):10;
      const farg=args.filter(a=>!a.startsWith('-')).pop();
      const fp=farg?rp(farg):null;const n=fp?FS[fp]:null;
      if(!n){err=`tail: ${farg||'?'}: No such file or directory`;break;}
      out=n.content.split('\n').slice(-n2).join('\n');
      if(follow)out+='\n[Simulated: following file. Ctrl+C to stop in real terminal.]';break;
    }
    case 'rm':{
      const name=args[args.length-1];const fp=rp(name);
      if(!FS[fp]){err=`rm: cannot remove '${name}': No such file or directory`;break;}
      if(FS[fp].type==='dir'&&!args.includes('-r')&&!args.includes('-rf')){err=`rm: cannot remove '${name}': Is a directory`;break;}
      const par=fp.slice(0,fp.lastIndexOf('/'))||'/';
      if(FS[par])FS[par].children=FS[par].children.filter(c=>c!==fp.split('/').pop());
      delete FS[fp];break;
    }
    case 'cp':{
      if(args.length<3){err='cp: missing operand';break;}
      const src=rp(args[1]),dst=rp(args[2]);
      if(!FS[src]){err=`cp: '${args[1]}': No such file or directory`;break;}
      FS[dst]={...FS[src],content:FS[src].content};
      const par=dst.slice(0,dst.lastIndexOf('/'))||'/';
      if(FS[par]&&!FS[par].children.includes(dst.split('/').pop()))FS[par].children.push(dst.split('/').pop());break;
    }
    case 'mv':{
      if(args.length<3){err='mv: missing operand';break;}
      let src=rp(args[1]),dst=rp(args[2]);
      if(!FS[src]){err=`mv: '${args[1]}': No such file or directory`;break;}
      if(FS[dst]?.type==='dir')dst=norm(dst+'/'+src.split('/').pop());
      FS[dst]=FS[src];
      const sp=src.slice(0,src.lastIndexOf('/'))||'/';
      if(FS[sp])FS[sp].children=FS[sp].children.filter(c=>c!==src.split('/').pop());
      delete FS[src];
      const dp=dst.slice(0,dst.lastIndexOf('/'))||'/';
      if(FS[dp]&&!FS[dp].children.includes(dst.split('/').pop()))FS[dp].children.push(dst.split('/').pop());break;
    }
    case 'find':{
      const dir2=args[1]?rp(args[1]):S.cwd;
      const ni=args.indexOf('-name');
      const pattern=ni>=0?args[ni+1].replace(/\*/g,''):'';
      const results=[];
      const walk=p=>{const n=FS[p];if(!n)return;if(!pattern||p.split('/').pop().includes(pattern))results.push(p);if(n.type==='dir')n.children.forEach(c=>walk(norm(p+'/'+c)));};
      walk(dir2);out=results.join('\n');break;
    }
    case 'sort':{
      const farg=args.filter(a=>!a.startsWith('-')).pop();
      if(!farg||farg==='sort'){break;}
      const fp=rp(farg);const n=FS[fp];
      if(!n){err=`sort: ${farg}: No such file or directory`;break;}
      const ls2=n.content.split('\n').filter(Boolean);
      const num=args.includes('-n')||args.includes('-rn');const rev=args.includes('-r')||args.includes('-rn');
      ls2.sort(num?(a,b)=>parseFloat(a)-parseFloat(b):(a,b)=>a.localeCompare(b));
      if(rev)ls2.reverse();out=ls2.join('\n');break;
    }
    case 'uniq':{
      const farg=args.filter(a=>!a.startsWith('-')).pop();
      if(!farg){break;}const fp=rp(farg);const n=FS[fp];
      if(!n){err=`uniq: ${farg}: No such file or directory`;break;}
      const ls2=n.content.split('\n');out=ls2.filter((l,i)=>l!==ls2[i-1]).join('\n');break;
    }
    case 'awk':{
      const dFlag=args.indexOf('-F');const delim=dFlag>=0?args[dFlag+1]:' ';
      const farg=args[args.length-1];const fp=rp(farg);const n=FS[fp];
      if(!n){err=`awk: ${farg}: No such file or directory`;break;}
      const prog=args.find(a=>a.includes('print'));
      const ls2=n.content.split('\n').filter(Boolean);
      if(prog){
        const pm=prog.match(/\$(\d+)/g);
        if(pm){
          const fields=pm.map(f=>parseInt(f.slice(1))-1);
          out=ls2.map(l=>{const cols=l.split(delim);return fields.map(i=>cols[i]||'').join(' ');}).join('\n');
        }else out=ls2.join('\n');
      }else out=ls2.join('\n');break;
    }
    case 'sed':{
      const farg=args[args.length-1];const expr=args.find(a=>a.startsWith('s/'));
      if(!expr){err='sed: missing expression';break;}
      const fp=rp(farg);const n=FS[fp];
      if(!n){err=`sed: ${farg}: No such file or directory`;break;}
      const m=expr.match(/^s\/(.+?)\/(.+?)\/(g)?$/);
      if(m){const result=m[3]?n.content.split(m[1]).join(m[2]):n.content.replace(m[1],m[2]);
        if(args.includes('-i')){n.content=result;}else out=result;}
      else out=n.content;break;
    }
    case 'ps':out=`USER       PID %CPU %MEM COMMAND\nroot         1  0.0  0.1 /sbin/init\nroot       123  0.0  0.0 /usr/sbin/sshd\nuser       456  0.0  0.0 -bash\nuser       789  0.0  0.0 ps aux`;break;
    case 'bash':case 'sh':{
      const fp=args[1]?rp(args[1]):null;
      if(!fp){out='bash: interactive mode (simulated)';break;}
      const n=FS[fp];
      if(!n){err=`bash: ${args[1]}: No such file or directory`;break;}
      out=`[Executing ${args[1]}]\nHello, World!\n${new Date().toString()}`;break;
    }
    case 'man':out=args[1]?`${args[1]}(1) — Open the AI Instructor chat (🤖 button) for a full explanation.`:'What manual page do you want?';break;
    case 'chmod':case 'chown':case 'sudo':case 'apt':case 'apt-get':
    case 'systemctl':case 'journalctl':case 'ssh':case 'ssh-keygen':
    case 'ssh-copy-id':case 'scp':case 'rsync':case 'ping':case 'curl':
    case 'wget':case 'ip':case 'ifconfig':case 'ss':case 'netstat':case 'dig':
    case 'nslookup':case 'top':case 'htop':case 'kill':case 'killall':
    case 'pkill':case 'pgrep':case 'lsblk':case 'df':case 'du':
    case 'mount':case 'fdisk':case 'ufw':case 'last':case 'who':
      out=getSim(cmd,args);break;
    default:
      if(raw.includes('|')){handlePipe(raw);return;}
      err=`bash: ${cmd}: command not found`;
  }

  if(out!==null&&out!=='')out.split('\n').forEach(l=>tp('t-out',l));
  if(err)tp('t-r',err);
  askHint(raw,out,err);
}

function handlePipe(raw){
  const parts=raw.split('|').map(p=>p.trim());
  tp('t-dim','[pipe: '+parts.map(p=>p.split(' ')[0]).join(' | ')+']');
  const last=parts[parts.length-1];const lcmd=last.split(/\s+/)[0];
  const pat=last.split(/\s+/)[1];
  if(lcmd==='grep'&&pat)tp('t-out',`(lines matching "${pat.replace(/['"]/g,'')}") → use individual commands to see output`);
  else if(lcmd==='wc')tp('t-out','(count of lines from previous command)');
  else if(lcmd==='sort')tp('t-out','(sorted output)');
  else if(lcmd==='head'||lcmd==='tail')tp('t-out','(first/last N lines)');
  else if(lcmd==='awk')tp('t-out','(field-processed output)');
  else if(lcmd==='cut')tp('t-out','(extracted columns)');
  else tp('t-out','(pipe output)');
  askHint(raw,null,null);
}

async function askHint(cmd,out,err){
  const bar=document.getElementById('tHint');
  bar.className='t-ai';bar.textContent='// Analyzing...';
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:100,
        system:'You are a concise Linux instructor. In 1-2 sentences explain what the command does or why an error occurred. No markdown.',
        messages:[{role:'user',content:`Command: ${cmd}\nOutput: ${out||err||'(none)'}`}]})
    });
    const d=await r.json();
    bar.className='t-ai lit';bar.textContent='→ '+(d.content?.[0]?.text||'');
  }catch(e){bar.className='t-ai';bar.textContent=`// ${cmd} executed`;}
}

