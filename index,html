function addAI(text){
  const c=document.getElementById('chatMsgs'),d=document.createElement('div');
  d.className='cm';
  d.innerHTML=`<div class="cm-av ai">LF</div><div class="cm-body"><div class="cm-name">AI Instructor · ${new Date().toLocaleTimeString()}</div><div class="cm-text">${fmt(text)}</div></div>`;
  c.appendChild(d);c.scrollTop=c.scrollHeight;
}
function addUser(text){
  const c=document.getElementById('chatMsgs'),d=document.createElement('div');
  d.className='cm';
  d.innerHTML=`<div class="cm-av user">U</div><div class="cm-body"><div class="cm-name">You · ${new Date().toLocaleTimeString()}</div><div class="cm-text">${esc(text)}</div></div>`;
  c.appendChild(d);c.scrollTop=c.scrollHeight;
}
function addTyping(){
  const c=document.getElementById('chatMsgs'),d=document.createElement('div');
  d.className='cm';d.id='typing';
  d.innerHTML=`<div class="cm-av ai">LF</div><div class="cm-body"><div class="t-ind"><div class="t-dot"></div><div class="t-dot"></div><div class="t-dot"></div></div></div>`;
  c.appendChild(d);c.scrollTop=c.scrollHeight;
}
function rmTyping(){document.getElementById('typing')?.remove();}
function fmt(t){
  return t.replace(/```[\w]*([\s\S]*?)```/g,'<pre>$1</pre>')
    .replace(/`([^`]+)`/g,'<code>$1</code>')
    .replace(/\*\*([^*]+)\*\*/g,'<strong>$1</strong>')
    .replace(/\n/g,'<br>');
}
async function sendChat(){
  const inp=document.getElementById('chatInp');
  const text=inp.value.trim();
  if(!text||S.aiThinking)return;
  inp.value='';inp.style.height='auto';
  S.aiThinking=true;document.getElementById('chatSend').disabled=true;
  addUser(text);addTyping();
  S.chatHist.push({role:'user',content:text});
  const L=LESSONS[S.lesson];
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{
      method:'POST',headers:{'Content-Type':'application/json'},
      body:JSON.stringify({model:'claude-sonnet-4-6',max_tokens:1000,
        system:`You are an expert Linux instructor at the Linux Foundation. The student is studying: "${L?.title||'Linux'}". Give precise, professional answers. Use backticks for commands, triple backtick blocks for multi-line examples. Be thorough but concise. No excessive bullet points.`,
        messages:S.chatHist.slice(-14)})
    });
    const d=await r.json();
    const reply=d.content?.[0]?.text||'Connection error.';
    rmTyping();addAI(reply);S.chatHist.push({role:'assistant',content:reply});
  }catch(e){rmTyping();addAI('Network error — check your connection.');}
  S.aiThinking=false;document.getElementById('chatSend').disabled=false;
  document.getElementById('chatInp').focus();
}
function hck(e){
  if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendChat();}
  const ta=e.target;ta.style.height='auto';ta.style.height=Math.min(ta.scrollHeight,100)+'px';
}

// ── INIT ──────────────────────────────────────────────────────
buildSidebar();
loadLesson('filesystem');
initTerm();

</script>
