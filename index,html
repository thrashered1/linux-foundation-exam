  out.appendChild(d); out.scrollTop=out.scrollHeight;
}
function tprompt(cmd){
  const p=cwdD();
  tpHTML(`<span class="tp-u">user</span><span class="tp-a">@</span><span class="tp-h">lf</span>:<span class="tp-p">${p}</span><span class="tp-s">$ </span><span class="t-cmd">${esc(cmd)}</span>`);
}
function cwdD(){return S.cwd.replace('/home/user','~');}
function updPath(){document.getElementById('tPath').textContent=cwdD();}
function esc(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function rp(p){
  if(!p||p==='~')return'/home/user';
  if(p.startsWith('~/'))return'/home/user/'+p.slice(2);
  if(p.startsWith('/'))return norm(p);
  return norm(S.cwd+'/'+p);
}
function norm(p){
  const parts=p.split('/').filter(Boolean),r=[];
  for(const x of parts){if(x==='..')r.pop();else if(x!=='.')r.push(x);}
  return'/'+r.join('/');
}
function clearTerm(){document.getElementById('termOut').innerHTML='';}
function termHelp(){
  tp('t-dim','──────────────────────────────────────────────');
  tp('t-b','Available commands:');
  ['ls [-la] [path]   cd [path]        pwd','cat [file]         mkdir [-p] dir   touch [file]',
    'rm [-r] [path]    cp src dst       mv src dst','echo text           grep pat file    find dir -name',
    'wc -l file        cut -d: -f1 f    head/tail [-n] f','awk / sed          sort / uniq      ps aux',
    'whoami / id        uname -a          date / history   clear'].forEach(l=>tp('t-out','  '+l));
  tp('t-dim','──────────────────────────────────────────────');
}
function initTerm(){
  tp('t-g','Linux Foundation Interactive Shell  (bash 5.2)');
  tp('t-dim','Type \'help\' or click the help button. Tab to autocomplete.');
  tp('','');
}

function htk(e){
  if(e.key==='Enter'){const v=e.target.value.trim();e.target.value='';if(v){S.th.unshift(v);S.hi=-1;runCmd(v);}}
  else if(e.key==='ArrowUp'){e.preventDefault();if(S.hi<S.th.length-1)e.target.value=S.th[++S.hi];}
  else if(e.key==='ArrowDown'){e.preventDefault();S.hi>0?e.target.value=S.th[--S.hi]:(S.hi=-1,e.target.value='');}
  else if(e.key==='Tab'){e.preventDefault();tabComp(e.target);}
  else if(e.key==='l'&&e.ctrlKey){e.preventDefault();clearTerm();}
}

function tabComp(inp){
  const v=inp.value,parts=v.split(' '),last=parts[parts.length-1];
  if(!last)return;
  const dp=last.includes('/')?rp(last.slice(0,last.lastIndexOf('/')+1)):S.cwd;
  const pref=last.includes('/')?last.slice(last.lastIndexOf('/')+1):last;
  const node=FS[dp];if(!node||node.type!=='dir')return;
  const m=node.children.filter(c=>c.startsWith(pref));
  if(m.length===1){
    parts[parts.length-1]=(last.includes('/')?last.slice(0,last.lastIndexOf('/')+1):'')+m[0];
    const fp=norm(dp+'/'+m[0]);if(FS[fp]?.type==='dir')parts[parts.length-1]+='/';
    inp.value=parts.join(' ');
  }else if(m.length>1){tprompt(v);tp('t-dim',m.join('  '));}
}

